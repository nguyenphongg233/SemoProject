# ==========================================
# SEMO PROJECT ENVIRONMENT VARIABLES EXAMPLE
# ==========================================
# Copy this file to:
# - backend/.env (for backend variables)
# - frontend/.env (for frontend variables)
# Or define them in your deployment environment.

# ------------------------------------------
# BACKEND ENVIRONMENT VARIABLES
# (To be used by backend/src/main/resources/application.properties)
# ------------------------------------------

# Database credentials
DB_PASSWORD=your_db_password

# Server port
Port=8888

# JWT configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Email configuration
MAIL_USERNAME=semo.system.bot@gmail.com
MAIL_PASSWORD=your_mail_app_password

# ------------------------------------------
# FRONTEND ENVIRONMENT VARIABLES (Vite)
# (To be placed in frontend/.env)
# ------------------------------------------

# API URL (Should point to the backend server)
VITE_API_URL=http://localhost:8888

# Application Name
VITE_APP_NAME=SemoProject

# Auth Token Key (Used in LocalStorage)
VITE_AUTH_TOKEN_KEY=semo_auth_token

# VietQR Configuration (Used for wallet deposit)
VITE_VIETQR_BANK_ID=MB
VITE_VIETQR_ACCOUNT_NO=000000000
VITE_VIETQR_ACCOUNT_NAME=SEMO APP
